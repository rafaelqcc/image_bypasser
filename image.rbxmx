				<Item class="LocalScript" referent="RBXBFF9DFBD8A47428C99F786BC541FBA31">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local image = require(script.Parent)

local frame = script.Parent.Parent
local pixelTemplate = frame:FindFirstChild("pixel")

if not pixelTemplate then
	return
end

pixelTemplate.Visible = false

local mainLayout = frame:FindFirstChildOfClass("UIListLayout")
if mainLayout then
	mainLayout.FillDirection = Enum.FillDirection.Vertical
	mainLayout.Padding = UDim.new(0, 0)
end

for y = 1, #image do
	local row = Instance.new("Frame")
	row.Name = "Row" .. y
	row.BackgroundTransparency = 1
	row.BorderSizePixel = 0
	row.Size = UDim2.new(0, #image[y] * 3, 0, 3)

	local rowLayout = Instance.new("UIListLayout")
	rowLayout.FillDirection = Enum.FillDirection.Horizontal
	rowLayout.SortOrder = Enum.SortOrder.LayoutOrder
	rowLayout.Padding = UDim.new(0, 0)
	rowLayout.Parent = row

	for x = 1, #image[y] do
		local pixel = pixelTemplate:Clone()
		local color = image[y][x]

		pixel.BackgroundColor3 = Color3.fromRGB(color[1], color[2], color[3])
		pixel.Visible = true
		pixel.Parent = row
	end

	row.Parent = frame
end]]></ProtectedString>
