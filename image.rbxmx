				<Item class="LocalScript" referent="RBXBFF9DFBD8A47428C99F786BC541FBA31">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local image = require(script.Parent)

local frame = script.Parent.Parent
local pixelTemplate = frame:FindFirstChild("pixel")

if not pixelTemplate then
	warn("Pixel template not found!")
	return
end

-- Remove template from the frame so UIGridLayout doesn't reserve a cell for it
pixelTemplate.Parent = nil

-- Read dimensions directly from the image data (no hardcoded values)
local numRows = #image
local numCols = #image[1]

-- Clean up old layouts and constraints from previous runs
for _, child in frame:GetChildren() do
	if child:IsA("UIGridLayout") or child:IsA("UIListLayout") or child:IsA("UIAspectRatioConstraint") then
		child.Parent = nil
	end
end

-- UIGridLayout with Scale-based CellSize:
-- Each pixel = 1/numCols of the frame width, 1/numRows of the frame height
-- This means the grid always fills 100% of the ImageFrame, on any screen size
local gridLayout = Instance.new("UIGridLayout")
gridLayout.CellSize = UDim2.new(1 / numCols, 0, 1 / numRows, 0)
gridLayout.CellPadding = UDim2.new(0, 0, 0, 0)
gridLayout.SortOrder = Enum.SortOrder.LayoutOrder
gridLayout.FillDirection = Enum.FillDirection.Horizontal
gridLayout.StartCorner = Enum.StartCorner.TopLeft
gridLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
gridLayout.VerticalAlignment = Enum.VerticalAlignment.Top
gridLayout.Parent = frame

-- Keep all pixels inside the frame bounds
frame.ClipsDescendants = true

-- Generate all pixels with LayoutOrder for correct left-to-right, top-to-bottom ordering
local order = 0
for y = 1, numRows do
	for x = 1, #image[y] do
		local pixel = pixelTemplate:Clone()
		local color = image[y][x]

		pixel.BackgroundColor3 = Color3.fromRGB(color[1], color[2], color[3])
		pixel.Visible = true
		pixel.BorderSizePixel = 0
		pixel.LayoutOrder = order
		pixel.Parent = frame
		order = order + 1
	end
end]]></ProtectedString>
